{
  "description": "Configuration for demo Tests",
  "driver": {
    "type": "OHJSUnitTest",
    "test-timeout": "600000",
    "bundle-name": "com.ohos.calculator",
    "module-name": "phone_test",
    "shell-timeout": "600000",
    "testcase-timeout": "180000",
    "compile-mode": "esmodule",
    "coverage": true,
    "package-tool-path": "D:\\Local\\coverage\\node_modules\\@ohos\\coverage"
  },
  "kits": [
    {
      "run-command": [
        "power-shell wakeup",
        "uinput -T -g 688 2695 688 2000",
        "power-shell timeout -o 600000",
        "bm uninstall -n com.ohos.calculator"
      ],
      "teardown-command": [
        "power-shell suspend"
      ],
      "type": "ShellKit"
    },
    {
      "test-file-name": [
        "Calculator.hap",
        "CalculatorTest.hap"
      ],
      "type": "AppInstallKit",
      "cleanup-apps": true
    }
  ]
}
