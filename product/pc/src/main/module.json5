{
  "module": {
    "name": "pc",
    "type": "entry",
    "srcEntry": "./ets/Application/CalculatorAbilityStage.ets",
    "description": "$string:pc_desc",
    "mainElement": "com.ohos.calculator.CalculatorAbility",
    "deviceTypes": [
      "default"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "metadata": [
      {
        "name": "ArkTSPartialUpdate",
        "value": "true"
      },
      {
        "name": "partialUpdateStrictCheck",
        "value": "warn"
      },
      {
        "name": "license_file_path",
        "value": "/system/etc/noticeFile/Calculator.html"
      }
    ],
    "abilities": [
      {
        "name": "CalculatorAbility",
        "srcEntry": "./ets/Ability/CalculatorAbility.ets",
        "description": "$string:CalculatorAbility_desc",
        "icon": "$media:logo",
        "label": "$string:app_name",
        "launchType": "singleton",
        "startWindowIcon": "$media:start_icon",
        "startWindowBackground": "$color:color_main_bg",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ],
        "minWindowWidth": 362,
        "minWindowHeight": 772,
        "maxWindowWidth": 362,
        "maxWindowHeight": 772,
        "supportWindowMode": ["floating"]
      }
    ]
  }
}